# ═══════════════════════════════════════════════════════════════════
# .env.example — Barber Booking MVP
# Copia a .env y ajusta los valores para tu entorno.
# Las variables sin valor usan defaults seguros en código.
# ═══════════════════════════════════════════════════════════════════

# ── Postgres (usada en docker-compose.yml para la contraseña) ──
DB_PASSWORD=postgres

# ── Backend ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:${DB_PASSWORD:-postgres}@db:5432/barberapp
APP_ENV=production
TIMEZONE=Europe/Madrid

# Admin credentials — OBLIGATORIO: sin default, la app falla si falta
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# JWT — si se deja vacío se genera uno aleatorio al reiniciar (invalida sesiones activas)
JWT_SECRET=cambia-este-secreto-jwt

# CORS — orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Frontend URL — para enlaces en emails
FRONTEND_URL=http://localhost:5173

# Rate limit en POST /book (peticiones/minuto por IP)
RATE_LIMIT_BOOK=5/minute

# Ventana de cancelación (horas antes de la cita)
CANCELLATION_WINDOW_HOURS=24

# Ventana de recordatorio (horas antes de la cita para enviar push/email)
REMINDER_WINDOW_HOURS=4

# Permitir reset de datos demo desde el panel admin
RESET_DEMO_ALLOWED=false

# ── SMTP (email transaccional) ───────────────────────────────────
# Vacío = modo solo logs (no envía emails reales)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Código de Caballeros Salon <barberia@ejemplo.com>"

# ── Google Business Profile ──────────────────────────────────────
# Place ID para enlace a reseñas (ej: "ChIJN1t_tDeuEmsRUsoyG83frY4")
GOOGLE_PLACE_ID=
GOOGLE_MAPS_API_KEY=

# ── Web Push (VAPID) ─────────────────────────────────────────────
# Generar con: python3 -c "from py_vapid import Vapid; v=Vapid(); v.generate(); print(v.public_key); print(v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=admin@codigodecaballeros.site
ADMIN_PANEL_URL=https://codigodecaballeros.site/admin.html

# ── Frontend (Vite dev server) ───────────────────────────────────
VITE_API_URL=http://localhost:8000
